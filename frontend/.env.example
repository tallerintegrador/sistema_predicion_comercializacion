# Base URL de la API SPC. Copiar a `.env` y ajustar si la API no corre en localhost:8010.
# La API debe levantarse con SPC_CORS_ORIGINS=http://localhost:5173 para aceptar este origen.
VITE_API_BASE_URL=http://localhost:8010

# Identificador de cliente que el frontend envía en el header X-Client-Id
# (opcional; alimenta el corpus incremental de la Fase A en el backend). Con el control de
# acceso activo (ADR-0014) el backend deriva el client_id del usuario autenticado y este
# header se ignora; sigue usándose solo si la API corre con SPC_AUTH_ENABLED=0.
VITE_CLIENT_ID=frontend-demo
