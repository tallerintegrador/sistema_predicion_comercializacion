# ---------------------------------------------------------------------------
# Configuración del backend SPC. Copiar a `.env` (NO se versiona) y completar.
# Sin `.env`, el sistema cae a SQLite local y guarda artefactos en disco: la app
# funciona igual, solo cambia DÓNDE viven los datos. Con estas variables, todo
# se persiste en Supabase (Postgres + Storage). Ver ADR-0027.
# ---------------------------------------------------------------------------

# --- Base de datos (Postgres/Supabase) -------------------------------------
# URL SQLAlchemy. OJO: el prefijo debe ser `postgresql+psycopg://` (driver psycopg 3).
# Tomar la cadena del "Session pooler" en Supabase (Connect → Connection string) y
# reemplazar el prefijo `postgresql://` por `postgresql+psycopg://`. Ejemplo:
#   postgresql+psycopg://postgres.<ref>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:5432/postgres
# Si se deja vacío, se usa SQLite local (data/spc.db).
SPC_DATABASE_URL=

# --- Supabase Storage (artefactos .joblib de los modelos) ------------------
# Si las tres están presentes, los modelos entrenados se suben al bucket; si no,
# caen a disco local (models/clientes/). SUPABASE_KEY debe ser la *service role key*
# (no la anon), porque el backend sube y borra artefactos.
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_BUCKET=spc-modelos

# --- Control de acceso (ADR-0014) ------------------------------------------
# Secreto para firmar tokens de sesión. En producción DEBE fijarse (si se deja vacío,
# se usa un secreto de DESARROLLO y los tokens son falsificables).
SPC_AUTH_SECRET=
# Activar/desactivar el control de acceso por roles (1=activo, 0=abierto). Por defecto activo.
SPC_AUTH_ENABLED=1

# --- CORS ------------------------------------------------------------------
# Orígenes permitidos (coma-separados). El frontend Vite corre en localhost:5173.
SPC_CORS_ORIGINS=http://localhost:5173
